# proto-file: indexing/config/bundle.proto
# proto-message: ProjectBundle

# Unique name for the communication bundle
bundle_name: "comm_svc"

# Core application logic
input: {
  directory: "src/main/java/com/enterprise/communication/"
}
input: {
  directory: "src/test/java/com/enterprise/communication/"
}

# APIs and interfaces
input: {
  directory: "api/communication/"
}

# Exclude large test data or noise patterns
exclude_pattern: ".*/testdata/.*"
exclude_pattern: ".*\\.log"
